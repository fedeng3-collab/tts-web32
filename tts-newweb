  .slider-label {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .studio-slider {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: rgba(255,255,255,0.1);
    cursor: none;
    outline: none;
  }

  .studio-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px; height: 16px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    cursor: none;
    box-shadow: 0 0 10px rgba(139,92,246,0.5);
    transition: transform 0.2s ease;
  }

  .studio-slider::-webkit-slider-thumb:hover { transform: scale(1.3); }

  .studio-output {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    padding: 20px;
    margin-top: 16px;
  }

  .studio-waveform {
    display: flex;
    align-items: center;
    gap: 2px;
    height: 48px;
    margin-bottom: 12px;
  }

  .studio-wave-bar {
    flex: 1;
    border-radius: 2px;
    background: linear-gradient(180deg, var(--neon-purple), var(--neon-blue));
    animation: studioWave 2s ease-in-out infinite;
    opacity: 0.7;
  }

  @keyframes studioWave {
    0%, 100% { height: 4px; opacity: 0.3; }
    50% { height: 100%; opacity: 1; }
  }

  .studio-playback-controls {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* ============================================
     ABOUT PAGE
  ============================================ */
  .about-hero {
    padding: 160px 80px 100px;
    text-align: center;
  }

  .mission-section {
    padding: 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .mission-visual {
    position: relative;
  }

  .mission-graphic {
    background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(59,130,246,0.08));
    border: 1px solid rgba(139,92,246,0.25);
    border-radius: 24px;
    padding: 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .mission-graphic::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(139,92,246,0.2), transparent 70%);
