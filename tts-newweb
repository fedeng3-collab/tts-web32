  /* ============================================
     MOBILE NAV
  ============================================ */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: none;
    padding: 4px;
  }

  .mobile-menu-btn span {
    display: block;
    width: 24px; height: 2px;
    background: white;
    border-radius: 1px;
