  .studio-textarea {
    width: 100%;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    padding: 20px;
    color: white;
    font-size: 15px;
    line-height: 1.7;
    font-family: var(--font-body);
    resize: none;
    height: 140px;
    transition: var(--transition-smooth);
    outline: none;
