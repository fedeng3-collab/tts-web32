  .mission-number {
    font-family: var(--font-heading);
    font-size: 120px;
    font-weight: 700;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    position: relative;
  }

  .mission-number-label {
    font-size: 16px;
    color: var(--text-muted);
    font-weight: 500;
    position: relative;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding: 0 80px 80px;
  }

  .value-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    padding: 32px;
    transition: var(--transition-smooth);
    cursor: none;
  }

  .value-card:hover {
    border-color: rgba(139,92,246,0.3);
    transform: translateY(-6px);
  }

  .value-card h3 {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .value-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ============================================
     API PAGE
  ============================================ */
  .code-block {
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(139,92,246,0.2);
    border-radius: 16px;
    padding: 28px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.8;
    overflow: auto;
    position: relative;
  }

  .code-block::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--neon-purple), var(--neon-cyan), transparent);
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .code-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
  }

  .code-dot-1 { background: #FF5F57; }
  .code-dot-2 { background: #FFBD2E; }
  .code-dot-3 { background: #28CA41; }

  .code-keyword { color: #C084FC; }
  .code-string { color: #34D399; }
  .code-comment { color: rgba(255,255,255,0.3); }
  .code-function { color: #60A5FA; }
  .code-variable { color: #F9A8D4; }
  .code-number { color: #FDE68A; }

  .integration-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding: 0 80px 80px;
  }

  .integration-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 28px;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: var(--transition-smooth);
    cursor: none;
  }

  .integration-card:hover {
    border-color: rgba(139,92,246,0.3);
    background: rgba(139,92,246,0.04);
    transform: translateX(6px);
  }

  .integration-logo {
    width: 52px; height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
  }

  .integration-card h4 {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    color: white;
    margin-bottom: 4px;
  }

  .integration-card p {
    font-size: 13px;
    color: var(--text-muted);
  }

  /* ============================================
     DIVIDER
  ============================================ */
  .gradient-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--neon-purple), var(--neon-blue), var(--neon-cyan), transparent);
    opacity: 0.3;
  }

  /* ============================================
     STAT COUNTERS
  ============================================ */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding: 80px;
    background: rgba(255,255,255,0.015);
  }

  .stat-item {
    text-align: center;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 52px;
    font-weight: 700;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 14px;
    color: var(--text-muted);
