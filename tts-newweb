    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  
  document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => {
    scrollObserver.observe(el);
  });
});

// Re-init on scroll
