    }
    
    // Pulse animation
    this.style.transform = 'scale(1.3)';
    setTimeout(() => { this.style.transform = ''; }, 200);
  });
});

/* ============================================
   SEARCH BAR TYPING EFFECT
============================================ */
const searchInput = document.querySelector('.search-bar input');
if (searchInput) {
  searchInput.addEventListener('focus', function() {
    this.parentElement.style.transform = 'scale(1.02)';
    this.parentElement.querySelector('.search-icon').style.color = 'var(--neon-purple)';
  });
  searchInput.addEventListener('blur', function() {
    this.parentElement.style.transform = '';
    this.parentElement.querySelector('.search-icon').style.color = '';
  });
}

/* ============================================
   STUDIO TAB CONTENT SWITCHING
============================================ */
document.querySelectorAll('.studio-tab').forEach((tab, index) => {
  tab.addEventListener('click', function() {
    const textarea = document.querySelector('.studio-textarea');
    const texts = [
      "Welcome to ORIVOX — the future of AI voice generation. Transform any text into studio-quality speech with unmatched realism and expression.",
      "Upload a voice sample to clone it. ORIVOX will create a perfect digital twin of your voice in minutes.",
      "My Projects — 12 projects created. Total audio: 3h 24min. Credits remaining: 48,200 characters."
    ];
    if (textarea && texts[index]) {
      textarea.value = texts[index];
    }
  });
});

/* ============================================
   ANIMATED COUNTER ON SCROLL
============================================ */
function animateCounters() {
  document.querySelectorAll('.stat-number').forEach(counter => {
    if (counter.dataset.animated) return;
    const rect = counter.getBoundingClientRect();
    if (rect.top < window.innerHeight) {
      counter.dataset.animated = 'true';
      counter.style.opacity = '0';
      setTimeout(() => {
        counter.style.transition = 'opacity 0.5s ease';
        counter.style.opacity = '1';
      }, 100);
    }
  });
}

window.addEventListener('scroll', animateCounters, { passive: true });

