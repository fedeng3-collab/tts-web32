<script>
/* ============================================
   CURSOR
============================================ */
const cursor = document.getElementById('cursor');
const cursorTrail = document.getElementById('cursorTrail');
let mouseX = 0, mouseY = 0;
let trailX = 0, trailY = 0;

document.addEventListener('mousemove', (e) => {
  mouseX = e.clientX;
  mouseY = e.clientY;
  cursor.style.left = mouseX - 6 + 'px';
  cursor.style.top = mouseY - 6 + 'px';
});

// Trail with delay
function animateTrail() {
  trailX += (mouseX - trailX) * 0.12;
  trailY += (mouseY - trailY) * 0.12;
  cursorTrail.style.left = trailX - 20 + 'px';
  cursorTrail.style.top = trailY - 20 + 'px';
  requestAnimationFrame(animateTrail);
}
animateTrail();

document.addEventListener('mousedown', () => {
  cursor.classList.add('clicked');
  cursorTrail.classList.add('clicked');
});

document.addEventListener('mouseup', () => {
  cursor.classList.remove('clicked');
  cursorTrail.classList.remove('clicked');
});

// Magnetic effect on buttons
document.querySelectorAll('.btn-primary, .btn-hero-primary, .btn-ghost, .btn-hero-secondary, .filter-pill, .voice-play-btn, .play-btn-small').forEach(btn => {
  btn.addEventListener('mousemove', (e) => {
    const rect = btn.getBoundingClientRect();
    const x = e.clientX - rect.left - rect.width / 2;
    const y = e.clientY - rect.top - rect.height / 2;
    btn.style.transform = `translate(${x * 0.12}px, ${y * 0.12}px) scale(1.03)`;
  });
  btn.addEventListener('mouseleave', () => {
    btn.style.transform = '';
  });
});

/* ============================================
   NAVIGATION SCROLL
============================================ */
const nav = document.getElementById('mainNav');
window.addEventListener('scroll', () => {
  if (window.scrollY > 20) {
    nav.classList.add('scrolled');
  } else {
    nav.classList.remove('scrolled');
  }
}, { passive: true });

/* ============================================
   PAGE NAVIGATION
============================================ */
const pageTransition = document.getElementById('pageTransition');
let currentPage = 'home';

function navigateTo(pageName) {
  if (pageName === currentPage) return;
  
  // Animate out
  pageTransition.style.transform = 'translateX(-100%)';
  pageTransition.style.transition = 'none';
  pageTransition.offsetHeight; // reflow
  pageTransition.style.transition = 'transform 0.45s cubic-bezier(0.76, 0, 0.24, 1)';
  pageTransition.style.transform = 'translateX(0)';
  
  setTimeout(() => {
    // Switch pages
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const nextPage = document.getElementById('page-' + pageName);
    if (nextPage) {
      nextPage.classList.add('active');
      currentPage = pageName;
      window.scrollTo(0, 0);
      
      // Initialize page elements
      initWaveforms();
      initScrollAnimations();
      
      // Animate in
      pageTransition.style.transition = 'transform 0.45s cubic-bezier(0.76, 0, 0.24, 1)';
      pageTransition.style.transform = 'translateX(100%)';
      
      setTimeout(() => {
        pageTransition.style.transition = 'none';
        pageTransition.style.transform = 'translateX(-100%)';
      }, 450);
    }
  }, 350);
}

/* ============================================
   WAVEFORM GENERATION
============================================ */
function initWaveforms() {
  // Hero waveform
  const heroWaveform = document.getElementById('heroWaveform');
  if (heroWaveform) {
    heroWaveform.innerHTML = '';
    for (let i = 0; i < 28; i++) {
      const bar = document.createElement('div');
      bar.className = 'wave-bar';
      const height = Math.random() * 80 + 10;
      bar.style.height = height + '%';
      bar.style.animationDelay = (i * 0.06) + 's';
      bar.style.animationDuration = (0.8 + Math.random() * 0.8) + 's';
      heroWaveform.appendChild(bar);
    }
  }

  // Voice card mini waves
  ['wave1','wave2','wave3','wave4'].forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.innerHTML = '';
      for (let i = 0; i < 20; i++) {
        const bar = document.createElement('div');
        bar.className = 'mini-bar';
        const h = Math.random() * 80 + 10;
        bar.style.height = h + '%';
        bar.style.animationDelay = (i * 0.08) + 's';
        bar.style.animationDuration = (0.6 + Math.random() * 0.6) + 's';
        el.appendChild(bar);
      }
    }
  });

  // All waveforms in voice cards
  document.querySelectorAll('.waveform').forEach(wf => {
    if (!wf.id) {
      wf.innerHTML = '';
      for (let i = 0; i < 24; i++) {
        const bar = document.createElement('div');
        bar.className = 'wave-bar';
        const h = Math.random() * 80 + 10;
        bar.style.height = h + '%';
        bar.style.animationDelay = (i * 0.06) + 's';
        bar.style.animationDuration = (0.7 + Math.random() * 0.7) + 's';
        wf.appendChild(bar);
      }
    }
  });
}

/* ============================================
   SCROLL ANIMATIONS
============================================ */
function initScrollAnimations() {
  const reveals = document.querySelectorAll('.page.active .reveal, .page.active .reveal-left, .page.active .reveal-right, .page.active .reveal-scale');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  
  reveals.forEach(el => observer.observe(el));
  
  // Also trigger visible elements immediately
  setTimeout(() => {
    reveals.forEach(el => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight) {
        el.classList.add('revealed');
      }
    });
  }, 100);
}

/* ============================================
   PARALLAX ON MOUSE MOVE
============================================ */
document.addEventListener('mousemove', (e) => {
  const centerX = window.innerWidth / 2;
  const centerY = window.innerHeight / 2;
  const moveX = (e.clientX - centerX) / centerX;
  const moveY = (e.clientY - centerY) / centerY;
  
  // Move orbs subtly
  const orbs = document.querySelectorAll('.bg-orb');
  orbs.forEach((orb, i) => {
    const factor = (i + 1) * 8;
    orb.style.transform = `translate(${moveX * factor}px, ${moveY * factor}px)`;
  });
  
  // Float panels parallax
  const floatPanels = document.querySelectorAll('.float-panel');
  floatPanels.forEach((panel, i) => {
    const factor = (i % 2 === 0 ? 1 : -1) * 6;
    panel.style.transform = `translateY(${moveY * factor}px) translateX(${moveX * factor * 0.5}px)`;
  });
  
  // Hero rings subtle movement
  const rings = document.querySelectorAll('.hero-ring');
  rings.forEach((ring, i) => {
    ring.style.transform = `translate(calc(-50% + ${moveX * (i+1) * 3}px), calc(-50% + ${moveY * (i+1) * 3}px)) rotate(0deg)`;
  });
});

/* ============================================
   FILTER PILLS
============================================ */
document.querySelectorAll('.filter-pill').forEach(pill => {
  pill.addEventListener('click', function() {
    this.closest('.filter-bar, div').querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
    this.classList.add('active');
