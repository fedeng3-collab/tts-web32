<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ORIVOX — Give Intelligence a Voice</title>
<style>
  /* ============================================
     IMPORTS & ROOT VARIABLES
  ============================================ */
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

  :root {
    --bg-primary: #040408;
    --bg-secondary: #07070f;
    --bg-card: rgba(255,255,255,0.03);
    --bg-glass: rgba(255,255,255,0.05);
    --neon-purple: #8B5CF6;
    --neon-blue: #3B82F6;
    --neon-cyan: #06B6D4;
    --neon-magenta: #EC4899;
    --neon-indigo: #6366F1;
    --glow-purple: rgba(139,92,246,0.4);
    --glow-blue: rgba(59,130,246,0.4);
    --glow-cyan: rgba(6,182,212,0.3);
    --text-primary: #FFFFFF;
    --text-secondary: rgba(255,255,255,0.65);
    --text-muted: rgba(255,255,255,0.35);
    --border-subtle: rgba(255,255,255,0.08);
    --border-glow: rgba(139,92,246,0.3);
    --gradient-primary: linear-gradient(135deg, #8B5CF6, #3B82F6, #06B6D4);
    --gradient-text: linear-gradient(135deg, #ffffff 0%, #a78bfa 50%, #38bdf8 100%);
    --gradient-card: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(59,130,246,0.05));
    --font-heading: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --transition-smooth: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --transition-spring: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ============================================
     RESET & BASE
  ============================================ */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  
  html { scroll-behavior: smooth; overflow-x: hidden; }
  
  body {
    font-family: var(--font-body);
    background: var(--bg-primary);
    color: var(--text-primary);
    overflow-x: hidden;
    cursor: none;
    line-height: 1.6;
  }

  ::selection { background: rgba(139,92,246,0.4); color: white; }

  /* ============================================
     CUSTOM CURSOR
  ============================================ */
  .cursor {
    width: 12px; height: 12px;
    background: var(--neon-purple);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 99999;
    transition: transform 0.1s ease, opacity 0.3s ease;
    mix-blend-mode: screen;
    box-shadow: 0 0 20px var(--neon-purple), 0 0 40px rgba(139,92,246,0.5);
  }

  .cursor-trail {
    width: 40px; height: 40px;
    border: 1px solid rgba(139,92,246,0.4);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 99998;
    transition: all 0.15s ease;
    mix-blend-mode: screen;
  }

  .cursor.clicked { transform: scale(2); }
  .cursor-trail.clicked { transform: scale(0.5); border-color: var(--neon-cyan); }

  /* ============================================
     ANIMATED BACKGROUND
  ============================================ */
  .bg-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
    animation: orbFloat 20s ease-in-out infinite;
  }

  .bg-orb-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, #8B5CF6, transparent);
    top: -100px; left: -100px;
    animation-delay: 0s;
  }

  .bg-orb-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, #3B82F6, transparent);
    top: 30%; right: -150px;
    animation-delay: -7s;
  }

  .bg-orb-3 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, #06B6D4, transparent);
    bottom: 20%; left: 20%;
    animation-delay: -14s;
  }

  .bg-orb-4 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, #EC4899, transparent);
    bottom: -50px; right: 30%;
    animation-delay: -10s;
  }

  @keyframes orbFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(30px, -40px) scale(1.05); }
    50% { transform: translate(-20px, 30px) scale(0.95); }
    75% { transform: translate(40px, 20px) scale(1.02); }
  }

  .bg-grid {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
    background-image: 
      linear-gradient(rgba(139,92,246,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139,92,246,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* Neon light trails */
  .neon-trail {
    position: fixed;
    width: 2px;
    background: linear-gradient(180deg, transparent, var(--neon-purple), var(--neon-blue), transparent);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    animation: trailMove 8s ease-in-out infinite;
    filter: blur(1px);
  }

  .neon-trail-1 { left: 15%; height: 200px; animation-delay: 0s; }
  .neon-trail-2 { left: 35%; height: 150px; animation-delay: -2.5s; background: linear-gradient(180deg, transparent, var(--neon-cyan), transparent); }
  .neon-trail-3 { left: 60%; height: 250px; animation-delay: -5s; }
  .neon-trail-4 { left: 80%; height: 180px; animation-delay: -1.5s; background: linear-gradient(180deg, transparent, var(--neon-magenta), transparent); }

  @keyframes trailMove {
    0% { top: -250px; opacity: 0; }
    20% { opacity: 0.6; }
    80% { opacity: 0.6; }
    100% { top: 110vh; opacity: 0; }
  }

  /* ============================================
     NAVIGATION
  ============================================ */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 0 40px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: var(--transition-smooth);
    border-bottom: 1px solid transparent;
  }

  nav.scrolled {
    background: rgba(4,4,8,0.85);
    backdrop-filter: blur(24px);
    border-bottom-color: var(--border-subtle);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    cursor: none;
  }

  .logo-icon {
    width: 36px; height: 36px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-icon svg {
    width: 36px; height: 36px;
    filter: drop-shadow(0 0 8px var(--neon-purple));
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 3px;
    background: linear-gradient(135deg, #fff, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 14px;
    border-radius: 8px;
    transition: var(--transition-smooth);
    cursor: none;
    position: relative;
    overflow: hidden;
  }

  .nav-links a::before {
    content: '';
    position: absolute;
    bottom: 4px; left: 50%;
    transform: translateX(-50%);
    width: 0; height: 1px;
    background: var(--gradient-primary);
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: white;
    background: rgba(255,255,255,0.05);
  }

  .nav-links a:hover::before { width: 60%; }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    padding: 9px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    cursor: none;
    transition: var(--transition-smooth);
    font-family: var(--font-body);
  }

  .btn-ghost:hover {
    border-color: var(--neon-purple);
    color: white;
    background: rgba(139,92,246,0.08);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    color: white;
    padding: 9px 22px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    cursor: none;
    border: none;
    transition: var(--transition-smooth);
    font-family: var(--font-body);
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(139,92,246,0.3);
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left 0.5s ease;
  }

  .btn-primary:hover::before { left: 100%; }
  .btn-primary:hover {
    box-shadow: 0 0 40px rgba(139,92,246,0.6), 0 0 80px rgba(59,130,246,0.3);
    transform: translateY(-1px);
  }

  /* ============================================
     PAGES SYSTEM
  ============================================ */
  .page {
    display: none;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  .page.active { display: block; }

  /* ============================================
     PAGE TRANSITION OVERLAY
  ============================================ */
  .page-transition {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    z-index: 9999;
    transform: translateX(-100%);
    pointer-events: none;
  }

  .page-transition.entering {
    animation: pageEnter 0.6s cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  .page-transition.leaving {
    animation: pageLeave 0.6s cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  @keyframes pageEnter {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(0); }
  }

  @keyframes pageLeave {
    0% { transform: translateX(0); }
    100% { transform: translateX(100%); }
  }

  /* ============================================
     HERO SECTION
  ============================================ */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 80px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    max-width: 700px;
    z-index: 2;
    position: relative;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(139,92,246,0.1);
    border: 1px solid rgba(139,92,246,0.3);
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--neon-purple);
    margin-bottom: 32px;
    animation: fadeInUp 0.8s ease forwards;
    opacity: 0;
    animation-delay: 0.2s;
  }

  .hero-badge-dot {
    width: 6px; height: 6px;
    background: var(--neon-purple);
    border-radius: 50%;
    animation: pulseDot 2s ease-in-out infinite;
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(52px, 7vw, 96px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -2px;
    margin-bottom: 24px;
    animation: fadeInUp 0.8s ease forwards;
    opacity: 0;
    animation-delay: 0.4s;
  }

  .hero-title .line-1 { display: block; color: white; }
  .hero-title .line-2 {
    display: block;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 560px;
    margin-bottom: 44px;
    animation: fadeInUp 0.8s ease forwards;
    opacity: 0;
    animation-delay: 0.6s;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    align-items: center;
    animation: fadeInUp 0.8s ease forwards;
    opacity: 0;
    animation-delay: 0.8s;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    color: white;
    padding: 16px 32px;
    border-radius: 14px;
    font-size: 16px;
    font-weight: 600;
    cursor: none;
    border: none;
    transition: var(--transition-smooth);
    font-family: var(--font-body);
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 30px rgba(139,92,246,0.4), 0 20px 40px rgba(0,0,0,0.3);
    text-decoration: none;
  }

  .btn-hero-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--neon-blue), var(--neon-cyan));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .btn-hero-primary:hover::after { opacity: 1; }
  .btn-hero-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 60px rgba(139,92,246,0.7), 0 30px 60px rgba(0,0,0,0.4);
  }

  .btn-hero-primary span, .btn-hero-primary svg { position: relative; z-index: 1; }

  .btn-hero-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: white;
    padding: 16px 32px;
    border-radius: 14px;
    font-size: 16px;
    font-weight: 500;
    cursor: none;
    border: 1px solid rgba(255,255,255,0.15);
    transition: var(--transition-smooth);
    font-family: var(--font-body);
    text-decoration: none;
    backdrop-filter: blur(10px);
    background: rgba(255,255,255,0.04);
  }

  .btn-hero-secondary:hover {
    border-color: rgba(139,92,246,0.5);
    background: rgba(139,92,246,0.08);
    transform: translateY(-2px);
  }

  /* Hero Visual */
  .hero-visual {
    position: absolute;
    right: 0; top: 0;
    width: 55%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .hero-visual-inner {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Central glow sphere */
  .hero-sphere {
    position: absolute;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, rgba(139,92,246,0.3), rgba(59,130,246,0.2) 40%, rgba(6,182,212,0.1) 70%, transparent);
    animation: spherePulse 6s ease-in-out infinite;
    filter: blur(2px);
  }

  @keyframes spherePulse {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.05); opacity: 1; }
  }

  .hero-rings {
    position: absolute;
    width: 500px; height: 500px;
  }

  .hero-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    animation: ringRotate 20s linear infinite;
  }

  .hero-ring-1 {
    width: 400px; height: 400px;
    border-color: rgba(139,92,246,0.2);
    animation-duration: 25s;
  }

  .hero-ring-2 {
    width: 480px; height: 480px;
    border-color: rgba(59,130,246,0.15);
    animation-direction: reverse;
    animation-duration: 35s;
  }

  .hero-ring-3 {
    width: 550px; height: 550px;
    border-color: rgba(6,182,212,0.1);
    animation-duration: 45s;
  }

  @keyframes ringRotate {
    0% { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* Floating UI Panels */
  .float-panel {
    position: absolute;
    background: rgba(7,7,15,0.85);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(139,92,246,0.25);
    border-radius: 16px;
    padding: 16px 20px;
    animation: floatPanel 6s ease-in-out infinite;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .float-panel-waveform {
    top: 20%; left: -20px;
    width: 260px;
    animation-delay: 0s;
  }

  .float-panel-voice {
    bottom: 25%; left: -40px;
    width: 200px;
    animation-delay: -2s;
    animation-duration: 7s;
  }

  .float-panel-lang {
    top: 15%; right: 60px;
    width: 180px;
    animation-delay: -4s;
    animation-duration: 8s;
  }

  .float-panel-controls {
    bottom: 15%; right: 40px;
    width: 240px;
    animation-delay: -1s;
    animation-duration: 6.5s;
  }

  @keyframes floatPanel {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    33% { transform: translateY(-12px) rotate(0.5deg); }
    66% { transform: translateY(6px) rotate(-0.3deg); }
  }

  .panel-label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  /* Waveform animation */
  .waveform {
    display: flex;
    align-items: center;
    gap: 3px;
    height: 40px;
  }

  .wave-bar {
    width: 3px;
    background: linear-gradient(180deg, var(--neon-purple), var(--neon-blue));
    border-radius: 2px;
    animation: waveAnim 1.4s ease-in-out infinite;
  }

  .wave-bar:nth-child(2n) { background: linear-gradient(180deg, var(--neon-cyan), var(--neon-blue)); }
  .wave-bar:nth-child(3n) { background: linear-gradient(180deg, var(--neon-magenta), var(--neon-purple)); }

  @keyframes waveAnim {
    0%, 100% { height: 4px; opacity: 0.4; }
    50% { height: 100%; opacity: 1; }
  }

  /* Voice selector in panel */
  .voice-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .voice-item:last-child { border-bottom: none; }

  .voice-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    font-family: var(--font-heading);
  }

  .v1 { background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue)); }
  .v2 { background: linear-gradient(135deg, var(--neon-cyan), var(--neon-indigo)); }
  .v3 { background: linear-gradient(135deg, var(--neon-magenta), var(--neon-purple)); }

  .voice-info p { font-size: 12px; font-weight: 600; color: white; }
  .voice-info span { font-size: 10px; color: var(--text-muted); }

  /* Language pills */
  .lang-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .lang-pill {
    background: rgba(139,92,246,0.15);
    border: 1px solid rgba(139,92,246,0.25);
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 500;
    color: var(--neon-purple);
  }

  .lang-pill.active {
    background: linear-gradient(135deg, rgba(139,92,246,0.4), rgba(59,130,246,0.3));
    border-color: var(--neon-purple);
    color: white;
  }

  /* Playback controls */
  .playback {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .play-btn-small {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: none;
    box-shadow: 0 0 20px rgba(139,92,246,0.5);
    animation: glowPulse 2s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { box-shadow: 0 0 20px rgba(139,92,246,0.5); }
    50% { box-shadow: 0 0 40px rgba(139,92,246,0.8), 0 0 60px rgba(59,130,246,0.4); }
  }

  .playback-bar {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .playback-progress {
    height: 100%;
    background: linear-gradient(90deg, var(--neon-purple), var(--neon-cyan));
    border-radius: 2px;
    width: 35%;
    animation: progressAnim 4s ease-in-out infinite;
  }

  @keyframes progressAnim {
    0% { width: 0%; }
    100% { width: 100%; }
  }

  /* ============================================
     SCROLL ANIMATIONS
  ============================================ */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes fadeInRight {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(50px);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal-left.revealed { opacity: 1; transform: translateX(0); }

  .reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal-right.revealed { opacity: 1; transform: translateX(0); }

  .reveal-scale {
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal-scale.revealed { opacity: 1; transform: scale(1); }

  /* Stagger delays */
  .stagger-1 { transition-delay: 0.1s; }
  .stagger-2 { transition-delay: 0.2s; }
  .stagger-3 { transition-delay: 0.3s; }
  .stagger-4 { transition-delay: 0.4s; }
  .stagger-5 { transition-delay: 0.5s; }
  .stagger-6 { transition-delay: 0.6s; }

  /* ============================================
     SECTION SHARED STYLES
  ============================================ */
  section {
    padding: 120px 80px;
    position: relative;
  }

  .section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--neon-purple);
    margin-bottom: 20px;
    background: rgba(139,92,246,0.1);
    border: 1px solid rgba(139,92,246,0.25);
    padding: 5px 14px;
    border-radius: 100px;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .section-title .gradient-text {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 60px;
  }

  /* ============================================
     FEATURE STRIP
  ============================================ */
  .features-strip {
    padding: 60px 80px;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    background: rgba(255,255,255,0.015);
  }

  .features-strip-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }

  .strip-item {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .strip-icon {
    width: 44px; height: 44px;
    background: var(--gradient-card);
    border: 1px solid var(--border-glow);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .strip-text p {
    font-size: 14px;
    font-weight: 600;
    color: white;
    margin-bottom: 2px;
  }

  .strip-text span {
    font-size: 12px;
    color: var(--text-muted);
  }

  /* ============================================
     FEATURE CARDS
  ============================================ */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    padding: 32px;
    transition: var(--transition-smooth);
    position: relative;
    overflow: hidden;
    cursor: none;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gradient-card);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .feature-card::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue), var(--neon-cyan));
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-8px);
    border-color: transparent;
  }

  .feature-card:hover::before { opacity: 1; }
  .feature-card:hover::after { opacity: 0.6; }
  .feature-card:hover .feature-icon { box-shadow: 0 0 30px rgba(139,92,246,0.5); }

  .feature-card > * { position: relative; z-index: 1; }

  .feature-icon {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, rgba(139,92,246,0.2), rgba(59,130,246,0.1));
    border: 1px solid rgba(139,92,246,0.3);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: var(--transition-smooth);
  }

  .feature-card h3 {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 12px;
    color: white;
  }

  .feature-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .feature-card.featured {
    grid-column: span 2;
    background: linear-gradient(135deg, rgba(139,92,246,0.12), rgba(59,130,246,0.06));
    border-color: rgba(139,92,246,0.3);
  }

  /* ============================================
     VOICES PREVIEW
  ============================================ */
  .voices-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .voice-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 24px;
    transition: var(--transition-smooth);
    cursor: none;
    position: relative;
    overflow: hidden;
  }

  .voice-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gradient-primary);
    transform: scaleX(0);
    transition: transform 0.3s ease;
    transform-origin: left;
  }

  .voice-card:hover {
    border-color: rgba(139,92,246,0.3);
    transform: translateY(-6px);
    background: rgba(139,92,246,0.05);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 30px rgba(139,92,246,0.15);
  }

  .voice-card:hover::before { transform: scaleX(1); }

  .voice-card-avatar {
    width: 56px; height: 56px;
    border-radius: 50%;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    font-weight: 700;
    font-family: var(--font-heading);
    color: white;
    position: relative;
  }

  .voice-card-avatar::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    padding: 2px;
    background: var(--gradient-primary);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  .voice-card h4 {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    color: white;
    margin-bottom: 4px;
  }

  .voice-card .voice-meta {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .voice-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .voice-tag {
    background: rgba(139,92,246,0.1);
    border: 1px solid rgba(139,92,246,0.2);
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 11px;
    color: var(--neon-purple);
    font-weight: 500;
  }

  .voice-mini-wave {
    display: flex;
    align-items: center;
    gap: 2px;
    height: 24px;
    margin-bottom: 12px;
  }

  .mini-bar {
    width: 2px;
    border-radius: 1px;
    background: linear-gradient(180deg, var(--neon-purple), var(--neon-blue));
    animation: miniWave 1.2s ease-in-out infinite;
    opacity: 0.4;
  }

  .voice-card:hover .mini-bar { opacity: 1; }

  @keyframes miniWave {
    0%, 100% { height: 4px; }
    50% { height: 100%; }
  }

  .voice-play-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .voice-play-btn {
    width: 32px; height: 32px;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: none;
    transition: var(--transition-smooth);
  }

  .voice-play-btn:hover {
    transform: scale(1.2);
    box-shadow: 0 0 20px rgba(139,92,246,0.6);
  }

  /* ============================================
     USE CASES
  ============================================ */
  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .use-case-card {
    display: flex;
    gap: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    padding: 32px;
    transition: var(--transition-smooth);
    cursor: none;
    align-items: flex-start;
  }

  .use-case-card:hover {
    border-color: rgba(139,92,246,0.3);
    background: rgba(139,92,246,0.04);
    transform: translateX(6px);
    box-shadow: -4px 0 20px rgba(139,92,246,0.2);
  }

  .use-case-icon {
    width: 60px; height: 60px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 28px;
  }

  .use-case-card h3 {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 8px;
    color: white;
  }

  .use-case-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ============================================
     TESTIMONIALS
  ============================================ */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .testimonial-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    padding: 32px;
    position: relative;
    transition: var(--transition-smooth);
    cursor: none;
  }

  .testimonial-card:hover {
    border-color: rgba(139,92,246,0.25);
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }

  .testimonial-quote {
    font-size: 40px;
    color: var(--neon-purple);
    line-height: 1;
    margin-bottom: 16px;
    font-family: Georgia, serif;
    opacity: 0.6;
  }

  .testimonial-text {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .author-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    color: white;
    font-family: var(--font-heading);
  }

  .author-info p { font-size: 14px; font-weight: 600; color: white; }
  .author-info span { font-size: 12px; color: var(--text-muted); }

  .stars {
    display: flex;
    gap: 2px;
    margin-bottom: 16px;
  }

  .star { color: #FBBF24; font-size: 14px; }

  /* ============================================
     PRICING
  ============================================ */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    align-items: start;
  }

  .pricing-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    padding: 32px;
    transition: var(--transition-smooth);
    cursor: none;
    position: relative;
  }

  .pricing-card:hover {
    transform: translateY(-8px);
    border-color: rgba(139,92,246,0.3);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .pricing-card.featured {
    background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(59,130,246,0.08));
    border-color: var(--neon-purple);
    box-shadow: 0 0 40px rgba(139,92,246,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
    transform: translateY(-8px);
  }

  .pricing-card.featured:hover { transform: translateY(-14px); }

  .plan-badge {
    position: absolute;
    top: -12px; left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    color: white;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 4px 16px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .plan-name {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 8px;
  }

  .price-amount {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 700;
    color: white;
    line-height: 1;
  }

  .price-currency {
    font-size: 20px;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .price-period {
    font-size: 14px;
    color: var(--text-muted);
  }

  .plan-desc {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .plan-divider {
    height: 1px;
    background: var(--border-subtle);
    margin-bottom: 24px;
  }

  .plan-features {
    list-style: none;
    margin-bottom: 28px;
  }

  .plan-features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text-secondary);
    padding: 7px 0;
  }

  .feature-check {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .feature-cross {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .plan-cta {
    width: 100%;
    padding: 12px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    cursor: none;
    transition: var(--transition-smooth);
    font-family: var(--font-body);
    border: none;
  }

  .plan-cta-primary {
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    color: white;
    box-shadow: 0 0 20px rgba(139,92,246,0.3);
  }

  .plan-cta-primary:hover {
    box-shadow: 0 0 40px rgba(139,92,246,0.6);
    transform: translateY(-2px);
  }

  .plan-cta-ghost {
    background: transparent;
    border: 1px solid var(--border-subtle) !important;
    color: var(--text-secondary);
  }

  .plan-cta-ghost:hover {
    border-color: rgba(139,92,246,0.4) !important;
    color: white;
    background: rgba(139,92,246,0.08);
  }

  .toggle-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 60px;
  }

  .toggle-label {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .toggle-label.active { color: white; }

  .toggle-switch {
    width: 52px; height: 28px;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    border-radius: 14px;
    position: relative;
    cursor: none;
    transition: var(--transition-smooth);
    box-shadow: 0 0 20px rgba(139,92,246,0.3);
  }

  .toggle-knob {
    width: 22px; height: 22px;
    background: white;
    border-radius: 50%;
    position: absolute;
    top: 3px; left: 3px;
    transition: var(--transition-smooth);
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .toggle-switch.yearly .toggle-knob { left: 27px; }

  .yearly-badge {
    background: rgba(139,92,246,0.2);
    border: 1px solid rgba(139,92,246,0.3);
    color: var(--neon-purple);
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 100px;
  }

  /* ============================================
     ENTERPRISE CTA
  ============================================ */
  .enterprise-section {
    padding: 120px 80px;
  }

  .enterprise-card {
    background: linear-gradient(135deg, rgba(139,92,246,0.12), rgba(59,130,246,0.08), rgba(6,182,212,0.05));
    border: 1px solid rgba(139,92,246,0.3);
    border-radius: 32px;
    padding: 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .enterprise-card::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(139,92,246,0.15), transparent 70%);
    pointer-events: none;
  }

  .enterprise-card h2 {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 700;
    letter-spacing: -1.5px;
    margin-bottom: 20px;
    position: relative;
  }

  .enterprise-card p {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto 40px;
    line-height: 1.7;
    position: relative;
  }

  .enterprise-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    position: relative;
  }

  /* ============================================
     FOOTER
  ============================================ */
  footer {
    padding: 80px 80px 40px;
    border-top: 1px solid var(--border-subtle);
    position: relative;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 60px;
  }

  .footer-brand p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-top: 16px;
    max-width: 280px;
  }

  .footer-col h5 {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .footer-col ul { list-style: none; }
  .footer-col ul li { margin-bottom: 12px; }
  .footer-col ul li a {
    font-size: 14px;
    color: var(--text-secondary);
    text-decoration: none;
    cursor: none;
    transition: color 0.2s ease;
  }

  .footer-col ul li a:hover { color: white; }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 32px;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-bottom p {
    font-size: 13px;
    color: var(--text-muted);
  }

  .footer-socials {
    display: flex;
    gap: 12px;
  }

  .social-btn {
    width: 36px; height: 36px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: none;
    transition: var(--transition-smooth);
    color: var(--text-muted);
    font-size: 14px;
  }

  .social-btn:hover {
    border-color: rgba(139,92,246,0.4);
    color: white;
    background: rgba(139,92,246,0.1);
    box-shadow: 0 0 15px rgba(139,92,246,0.3);
  }

  /* ============================================
     VOICES PAGE
  ============================================ */
  .page-hero {
    padding: 160px 80px 80px;
    text-align: center;
    position: relative;
  }

  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 700;
    letter-spacing: -2px;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .page-hero p {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    padding: 0 80px;
  }

  .filter-pill {
    padding: 8px 20px;
    border-radius: 100px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 500;
    cursor: none;
    transition: var(--transition-smooth);
    font-family: var(--font-body);
  }

  .filter-pill:hover, .filter-pill.active {
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue));
    border-color: transparent;
    color: white;
    box-shadow: 0 0 20px rgba(139,92,246,0.3);
  }

  .search-bar {
    position: relative;
    margin-left: auto;
  }

  .search-bar input {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 10px 20px 10px 44px;
    color: white;
    font-size: 14px;
    font-family: var(--font-body);
    width: 260px;
    transition: var(--transition-smooth);
    outline: none;
  }

  .search-bar input:focus {
    border-color: rgba(139,92,246,0.4);
    box-shadow: 0 0 20px rgba(139,92,246,0.15);
  }

