/* ============================================
   STUDIO TABS
============================================ */
document.querySelectorAll('.studio-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    this.closest('.studio-tabs').querySelectorAll('.studio-tab').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
  });
});

/* ============================================
   PRICING TOGGLE
============================================ */
let isYearly = false;
const prices = {
  starter: [0, 0],
  pro: [22, 15],
  studio: [99, 69]
};

function toggleBilling() {
  isYearly = !isYearly;
  const toggle = document.getElementById('billingToggle');
  const monthly = document.getElementById('monthlyLabel');
  const yearly = document.getElementById('yearlyLabel');
  
  if (isYearly) {
    toggle.classList.add('yearly');
    monthly.classList.remove('active');
    yearly.classList.add('active');
  } else {
    toggle.classList.remove('yearly');
    monthly.classList.add('active');
    yearly.classList.remove('active');
  }
  
  // Animate price changes
  animatePrice('price-starter', prices.starter[isYearly ? 1 : 0]);
  animatePrice('price-pro', prices.pro[isYearly ? 1 : 0]);
  animatePrice('price-studio', prices.studio[isYearly ? 1 : 0]);
}

function animatePrice(id, target) {
  const el = document.getElementById(id);
  if (!el) return;
  const current = parseInt(el.textContent) || 0;
  const diff = target - current;
  const steps = 20;
  let step = 0;
  
  const interval = setInterval(() => {
    step++;
    const progress = step / steps;
    const eased = 1 - Math.pow(1 - progress, 3);
    el.textContent = Math.round(current + diff * eased);
    if (step >= steps) {
      clearInterval(interval);
      el.textContent = target;
    }
  }, 20);
}

/* ============================================
   TYPING ANIMATION
============================================ */
function initTyping() {
  const textarea = document.querySelector('.studio-textarea');
  if (!textarea) return;
  const text = "Welcome to ORIVOX — the future of AI voice generation. Transform any text into studio-quality speech with unmatched realism and expression.";
  let i = 0;
  textarea.value = '';
  
  function type() {
    if (i <= text.length) {
      textarea.value = text.substring(0, i);
      i++;
      setTimeout(type, 30 + Math.random() * 40);
    }
  }
  
  setTimeout(type, 1000);
}

