/* ============================================
   NEON TRAIL ANIMATION (Multiple instances)
============================================ */
function randomizeTrails() {
  document.querySelectorAll('.neon-trail').forEach(trail => {
    const randomDelay = Math.random() * 8;
    trail.style.animationDelay = `-${randomDelay}s`;
    trail.style.left = (Math.random() * 90 + 5) + '%';
    trail.style.height = (100 + Math.random() * 200) + 'px';
  });
}

/* ============================================
   FEATURE CARD TILT
============================================ */
document.querySelectorAll('.feature-card, .pricing-card, .voice-card, .testimonial-card').forEach(card => {
  card.addEventListener('mousemove', function(e) {
    const rect = this.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width - 0.5;
    const y = (e.clientY - rect.top) / rect.height - 0.5;
    const tiltX = y * 6;
    const tiltY = -x * 6;
    this.style.transform = `perspective(1000px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateY(-6px)`;
  });
  
  card.addEventListener('mouseleave', function() {
    this.style.transform = '';
    this.style.transition = 'all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
  });
});

