  /* ============================================
     RESPONSIVE
  ============================================ */
  @media (max-width: 1200px) {
    .pricing-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-top { grid-template-columns: 1fr 1fr 1fr; }
    .voices-full-grid { grid-template-columns: repeat(3, 1fr); }
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .feature-card.featured { grid-column: span 1; }
  }

  @media (max-width: 1024px) {
    section, .enterprise-section { padding: 80px 40px; }
    nav { padding: 0 24px; }
    .hero { padding: 120px 40px 80px; }
    .hero-visual { display: none; }
    .hero-content { max-width: 100%; }
    .studio-hero { grid-template-columns: 1fr; }
    .mission-section { grid-template-columns: 1fr; padding: 40px; }
    .voices-full-grid { padding: 0 40px 80px; }
    .filter-bar { padding: 0 40px; }
    .integration-grid { padding: 0 40px 80px; }
    .values-grid { padding: 0 40px 80px; }
    .features-strip-inner { grid-template-columns: repeat(2, 1fr); }
    .stats-row { padding: 40px; }
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .mobile-menu-btn { display: flex; }
    .features-grid { grid-template-columns: 1fr; }
    .voices-grid { grid-template-columns: repeat(2, 1fr); }
    .voices-full-grid { grid-template-columns: repeat(2, 1fr); }
    .use-cases-grid { grid-template-columns: 1fr; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .pricing-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .footer-top { grid-template-columns: 1fr; gap: 32px; }
    .integration-grid { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: 1fr; }
    .enterprise-card { padding: 40px 24px; }
    .enterprise-btns { flex-direction: column; align-items: center; }
    .hero-ctas { flex-direction: column; align-items: flex-start; }
    section { padding: 60px 24px; }
    footer { padding: 60px 24px 32px; }
    .features-strip { padding: 40px 24px; }
    .features-strip-inner { grid-template-columns: 1fr 1fr; }
    .hero { padding: 100px 24px 60px; }
    .page-hero { padding: 120px 24px 60px; }
    .about-hero { padding: 120px 24px 60px; }
    .studio-hero { padding: 120px 24px 60px; }
    .filter-bar { padding: 0 24px; }
    .voices-full-grid { padding: 0 24px 60px; }
    .integration-grid { padding: 0 24px 60px; }
    .values-grid { padding: 0 24px 60px; }
    .enterprise-section { padding: 60px 24px; }
  }

  /* ============================================
     UTILITY
  ============================================ */
  .text-center { text-align: center; }
  .flex-center { display: flex; align-items: center; justify-content: center; }
  .mb-0 { margin-bottom: 0 !important; }

  /* Glow border animated */
  .glow-border {
    position: relative;
  }

  .glow-border::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue), var(--neon-cyan), var(--neon-purple));
    background-size: 300% 300%;
    animation: gradientRotate 4s ease infinite;
    z-index: -1;
    opacity: 0.6;
  }

  @keyframes gradientRotate {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Number ticker animation */
  .ticker {
    display: inline-block;
    animation: tickerAnim 0.5s ease-out;
  }

  @keyframes tickerAnim {
    from { transform: translateY(-20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  /* Typing cursor */
  .typing-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: var(--neon-purple);
    animation: blink 1s step-end infinite;
    vertical-align: text-bottom;
    margin-left: 2px;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
</head>
